/* 全局样式重置 */
page {
  background-color: #e6f2e6dd;
  font-size: 28rpx;
  color: #333;
  height: 100%;
}

/* 背景图 */
.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

/* 主容器 */
.qrcode-container {
  padding: 0;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 自定义导航栏（和选择对接者页面统一） */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 75rpx;
  padding: 90rpx 24rpx 4rpx;

  background: #A5CFA9;
  backdrop-filter: blur(10rpx); /* 毛玻璃效果 */
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  position: sticky;
  top: 0;
  z-index: 99;
}

/* 返回按钮 */
.back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 返回图标 */
.back-icon {
  width: 20rpx;
  height: 30rpx;
}

/* 导航栏标题 */
.title {
  font-size: 34rpx;
  font-weight: 600;
  color: #207F4C;
}

.right {
  width: 80rpx;
}

/* 内容区域 */
.content {
  flex: 1;
  padding: 200rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 二维码卡片（增加边框/阴影） */
.qrcode-card {
  background-color: #fff;
  padding: 40rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

/* 二维码图片 */
.qrcode-img {
  width: 450rpx;
  height: 450rpx;
  display: block;
  margin-bottom: 30rpx;
  border: 10rpx solid #f8f8f8;
  border-radius: 16rpx;
}

/* 提示文字 */
.tip {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

/* 倒计时容器 */
.countdown {
  margin: 10rpx 0 30rpx;
}

/* 倒计时文字（突出显示） */
.countdown-text {
  font-size: 32rpx;
  color: #e64340;
  font-weight: 500;
}

/* 重新生成按钮 */
.regenerate-btn {
  width: 380rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(90deg, #2E7D32, #4CAF50); /* 渐变背景 */
  color: white;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 4rpx 15rpx rgba(46, 125, 50, 0.3);
  transition: all 0.2s ease;
}

.regenerate-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(46, 125, 50, 0.2);
}

/* 按钮组 */
.btn-group {
  width: 100%;
  display: flex;
  justify-content: center;
}

/* 查看交易记录按钮 */
.goto-list-btn {
  width: 380rpx;
  height: 88rpx;
  line-height: 64rpx;
  background: #fff;
  color: #2E7D32;
  border: 2rpx solid #2E7D32;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.goto-list-btn:active {
  background-color: #f5fcf5;
}