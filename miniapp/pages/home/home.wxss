/* pages/home/home.wxss */
/* 基础样式重置 */
page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
}
/* 自定义导航栏 */
.custom-nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background-color: #A5CFA9;
  z-index: 999;
}
.status-bar {
  width: 100%;
}
.nav-content {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #207F4C; 
}
/* 调整主内容容器的padding-top，适配自定义导航+搜索栏 */
.app-container {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding-top: calc(44px + env(safe-area-inset-top) + 80rpx);
  padding-bottom: 120rpx;
}
/* 背景图样式 */
.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 80%;
  z-index: -1;
}

/* 固定搜索栏 - 核心样式 */
.fixed-search-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background-color: #A5CFA9;
  z-index: 999; /* 置顶显示 */
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05); /* 底部阴影区分内容 */
}

/* 主容器 - 避开固定搜索栏 */
.app-container {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding-top: calc(270rpx + env(safe-area-inset-top)); /* 适配搜索栏高度+状态栏 */
  padding-bottom: 120rpx;
}

/* 通用布局工具类 */
.flex { display: flex; }
.justify-between { justify-content: space-between; }
.items-center { align-items: center; }
.gap-3 { gap: 24rpx; }
.px-4 { padding-left: 24rpx; padding-right: 24rpx; }
.py-2 { padding-top: 12rpx; padding-bottom: 12rpx; }
.mt-4 { margin-top: 24rpx; }
.mb-24 { margin-bottom: 120rpx; }
.text-center { text-align: center; }
.line-clamp-1 {
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.rounded-xl { border-radius: 24rpx; }
.rounded-full { border-radius: 9999rpx; }
.shadow-sm { box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06); }
.flex-1 { flex: 1; }
.flex-shrink-0 { flex-shrink: 0; }
.w-full { width: 100%; }
.h-full { height: 100%; }
.object-cover { object-fit: cover; }

/* 文字样式 */
.text-sm { font-size: 24rpx; }
.text-lg { font-size: 28rpx; }
.text-xl { font-size: 32rpx; }
.font-bold { font-weight: 600; }
.font-medium { font-weight: 500; }
.text-primary { color: #2E7D32; }
.text-gray-400 { color: #9ca3af; }
.text-gray-500 { color: #6b7280; }
.text-gray-700 { color: #374151; }
.text-red-500 { color: #e53935; }
.text-yellow { color: #ffd700; }
.text-white { color: #ffffff; }

/* 背景色 */
.bg-white { background-color: #ffffff; }
.bg-white-90 { background-color: rgba(255, 255, 255, 0.9); }
.bg-green-light { background-color: rgba(46, 125, 50, 0.08); }
.bg-green { background-color: #2E7D32; }

/* ========== 核心模块样式 ========== */
/* 状态栏占位 */
.status-bar {
  height: env(safe-area-inset-top);
  background-color: transparent;
}

/* 搜索栏 - 美化升级 */
.search-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 4rpx 24rpx 15rpx;
}
.search-box {
  flex: 1;
  height: 80rpx;
  background-color: #ffffff;
  border-radius: 40rpx;
  padding: 0 24rpx ;
  margin-right: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(46, 125, 50, 0.05);
  border: none;
}
.search-icon-img {
  width: 52rpx;
  height: 52rpx;
  margin-right: 16rpx;
}
.search-placeholder {
  font-size: 28rpx;
  color: #b0b7b3;
}
.scan-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  box-shadow: 0 2rpx 12rpx rgba(46, 125, 50, 0.1);
}
.scan-icon-img {
  width: 50rpx;
  height: 50rpx;
}

/* 轮播图 - 美化升级 */
.swiper {
  width: 100%;
  height: 340rpx;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(38, 38, 38, 0.08);
}
.swiper-item {
  position: relative;
  width: 100%;
  height: 100%;
}
.swiper-image {
  width: 100%;
  height: 100%;
}
.swiper-title {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.6), transparent);
  color: white;
  font-size: 30rpx;
  padding: 24rpx 28rpx;
  font-weight: 500;
}

/* 区块头部 - 统一美化 */
.section-header {
  margin-bottom: 24rpx;
}
.header-left {
  gap: 12rpx;
  align-items: center;
}
.header-icon-img {
  width: 60rpx;
  height: 60rpx;
}
.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #207F4C;
}
.tab-switch {
  display: flex;
  background-color: #f2f7f4;
  border-radius: 32rpx;
  padding: 6rpx;
  margin-left: 12rpx;
}
.tab-item {
  padding: 10rpx 28rpx;
  font-size: 26rpx;
  color: #588a58;
  border-radius: 28rpx;
  transition: all 0.3s ease;
}
.tab-item.active {
  background-color: #9dcfa2;
  color: white;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(46, 125, 50, 0.2);
}
.header-right {
  display: flex;
  align-items: center;
  color: #6a9e6a;
  font-size: 26rpx;
}
.more-text {
  margin-right: 8rpx;
}
.arrow {
  font-size: 32rpx;
  line-height: 1;
}

/* 公告区域 - 美化升级 */
.notice-list {
  background-color: #ffffffc5;
  border-radius: 24rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.notice-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f7f2;
}
.notice-item:last-child {
  border-bottom: none;
}
.notice-content {
  flex: 1;
  font-size: 28rpx;
  color: #263238;
  margin-right: 24rpx;
}
.notice-time {
  font-size: 24rpx;
  color: #90a4ae;
  flex-shrink: 0;
}

/* 横向滚动卡片 - 美化升级 */
.scroll-view {
  width: 100%;
  background-color: #ffffffc5;
  border-radius: 24rpx;
  padding: 24rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
  white-space: nowrap;
}
.scroll-view::-webkit-scrollbar { display: none; }
.scroll-content {
  display: inline-flex;
  padding-bottom: 8rpx;
}
.scroll-item {
  width: 220rpx;
  height: 220rpx;
  border-radius: 28rpx;
  background-color: #f8fbf8;
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}
.item-image {
  width: 100%;
  height: 100%;
}
.protected-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  background-color: #ff9800;
  color: white;
  font-size: 20rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 500;
}
.item-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(to top, rgba(36, 35, 35, 0.644), transparent);
  color: white;
  padding: 20rpx 16rpx 12rpx;
}
.item-title {
  font-size: 26rpx;
  margin-bottom: 6rpx;
}
.item-price {
  font-size: 30rpx;
  font-weight: bold;
  color: #fbe04b;
}
.empty-scroll-item {
  width: 220rpx;
  height: 220rpx;
  background-color: #f0f7f2;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #aaa;
  font-size: 24rpx;
  flex-shrink: 0;
}

/* 推荐网格 - 美化升级 */
.recommend-grid {
  background-color: #ffffffc5;
  border-radius: 24rpx;
  padding: 50rpx 30rpx;
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}
.recommend-card {
  background-color: white;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  transition: transform 0.2s ease;
}
.recommend-card:active {
  transform: scale(0.98);
}
.card-image {
  width: 100%;
  height: 220rpx;
}
.card-content {
  padding: 20rpx;
}
.card-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #263238;
  margin-bottom: 10rpx;
}
.card-price {
  font-size: 30rpx;
  font-weight: 600;
  color: #eb6461;
  display: block;
}
.card-time {
  font-size: 24rpx;
  color: #90a4ae;
  display: block;
  margin-top: 6rpx;
}

/* 空状态/加载提示 */
.empty-tip {
  text-align: center;
  color: #aaa;
  font-size: 28rpx;
  padding: 60rpx 0;
  background-color: rgba(255,255,255,0.8);
  border-radius: 24rpx;
}
.empty-tip.center {
  padding: 80rpx 0;
}
.loading-more, .no-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 26rpx;
  color: #999;
}

/* 网络错误提示 */
.network-error {
  text-align: center;
  padding: 40rpx;
}
.error-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}
.refresh-btn {
  display: inline-block;
  padding: 16rpx 40rpx;
  background-color: #2E7D32;
  color: white;
  border-radius: 40rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(46, 125, 50, 0.2);
}

/* 底部占位 */
.tabbar-placeholder {
  height: 120rpx;
}