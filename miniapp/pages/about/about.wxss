/* pages/about/about.wxss */
page {
  background: #e6f2e6;
  height: 100%;
  padding: 0;
  margin: 0;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
}

.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

.about-container {
  width: 100%;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 自定义导航栏（修复：top设为0，固定在顶部） */
.nav-box {
  width: 100%;
  background: #A5CFA9;
  height: 88rpx;
  box-sizing: border-box;
  position: sticky;
  top: 0; /* 关键：改回0，否则导航栏错位 */
  z-index: 100;
  padding-top: var(--status-bar-height, 20px);
}

.nav-bar {
  height: 198rpx;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  box-sizing: border-box;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  flex-shrink: 0;
}

.back-icon {
  padding-left: 10rpx;
  width: 20rpx;
  height: 32rpx;
  object-fit: contain;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #207F4C;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.nav-right {
  width: 60rpx;
  flex-shrink: 0;
}

/* 内容区域 */
.content {
  width: 100%;
  box-sizing: border-box;
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* logo区域（唯一样式：确保一行显示） */
.logo-box {
  display: flex;          /* 横向排列 */
  align-items: center;    /* 垂直居中 */
  justify-content: center;/* 整体水平居中 */
  margin-bottom: 40rpx;
  padding-top: 170rpx;
  width: 100%;            /* 占满宽度，方便居中 */
}

.logo-icon {
  width: 180rpx;
  height: 180rpx;
  object-fit: contain;
  margin-right: 20rpx;    /* 图标和文字间距 */
  flex-shrink: 0;         /* 防止图标被压缩 */
}

.logo-text-wrap {
  display: flex;
  flex-direction: column; /* 文字和版本号纵向排列 */
  justify-content: center;/* 垂直居中对齐图标 */
}

.logo-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #2E7D32;
  text-shadow: 0 2rpx 8rpx rgba(46, 125, 50, 0.15);
  margin-bottom: 10rpx;
}

.version {
  font-size: 24rpx;
  color: #999;
}

/* 介绍文本区域（首行缩进） */
.intro-box {
  width: 100%;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 60rpx;
}

.intro-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #207F4C;
  margin-bottom: 24rpx;
  text-align: center;
}

.intro-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  text-align: justify;
  text-indent: 2em; /* 首行缩进2字符 */
}

/* 协议链接区域 */
.links-box {
  display: flex;
  gap: 60rpx;
  align-items: center;
}

.link-item {
  font-size: 28rpx;
  color: #2E7D32;
  text-decoration: underline;
  padding: 10rpx 0;
}

.link-item:active {
  color: #19612c;
}