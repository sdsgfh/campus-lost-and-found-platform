/* pages/profile/other.wxss */
.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

page {
  background-color: #e6f2e6dd;
}

.profile-container {
  width: 100%;
  min-height: 100vh;
  backdrop-filter: blur(10rpx);
  padding: 24rpx;
  padding-top: 218rpx; /* 给自定义导航留空间 */
  box-sizing: border-box;
}

/* 自定义导航栏（参考detail页面） */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 188rpx;
  padding: 90rpx 24rpx 4rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #A5CFA9;
  z-index: 999;
  box-sizing: border-box;
}
.back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.back-icon {
  width: 20rpx;
  height: 30rpx;
}
.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #207F4C;
}
.nav-right {
  width: 60rpx;
}

/* 用户卡片 */
.user-card {
  background: white;
  border-radius: 24rpx;
  padding: 82rpx 40rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  margin-bottom: 24rpx;
}
.avatar {
  width: 190rpx;
  height: 190rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}
.info {
  flex: 1;
}
.nickname {
  font-size: 44rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 28rpx;
}

/* 信誉等级+荣誉称号（参考detail页面） */
.credit-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 42rpx;
}
.credit-level-wrap {
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.credit-icon {
  width: 30rpx;
  height: 30rpx;
}
.credit-level-text {
  font-size: 28rpx;
  color: #666;
}
.honor {
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.honor-icon {
  width: 38rpx;
  height: 38rpx;
}
.honor-text {
  font-size: 28rpx;
  color: #ff9800;
}

.report-btn {
  background: #70a88a;
  color: #f8f3f3;
  margin: 60rpx 30rpx 30rpx;
  border-radius: 12rpx;
  padding: 32rpx;
  text-align: center;
  font-size: 32rpx;
}

/* 信誉信息板块 */
.section {
  background: white;
  border-radius: 24rpx;
  padding: 64rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #529f64;
  margin-bottom: 36rpx;
  display: block;
}
.info-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 30rpx;
}
.info-item:last-child {
  margin-bottom: 0;
}
.label {
  color: #999;
  width: 200rpx;
}
.value {
  color: #207F4C;
  font-size: 60rpx;
  font-weight: 700;
  flex: 1;
}