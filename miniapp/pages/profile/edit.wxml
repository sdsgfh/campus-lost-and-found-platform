<!-- 背景图 -->
<image class="page-bg" src="/images/波浪.png"></image>

<view class="edit-container">
  <!-- 优化后的自定义导航栏 -->
  <view class="nav-bar">
    <view class="back-btn" bindtap="goBack">
      <image class="back-icon" src="/images/返回.png" mode="widthFix"></image>
    </view>
    <text class="nav-title">编辑资料</text>
    <view class="nav-right"></view>
  </view>

  <scroll-view scroll-y class="form-scroll" enhanced show-scrollbar="{{false}}">
    <view class="form-container">
      <!-- 头像 -->
      <view class="form-item avatar-item">
        <view class="avatar-wrapper" bindtap="changeAvatar">
          <image class="avatar" src="{{avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
          <view class="change-mask">
            <text class="change-text">点击更换</text>
          </view>
        </view>
      </view>

      <!-- 昵称 -->
      <view class="form-item input-item">
        <text class="label">昵称</text>
        <input 
          class="input" 
          placeholder="请输入昵称" 
          value="{{nickname}}" 
          bindinput="onNicknameInput" 
          maxlength="20" 
        />
        <text class="word-count">{{nickname.length}}/20</text>
      </view>

      <!-- 个人简介 -->
      <view class="form-item textarea-item">
        <text class="label">个人简介</text>
        <textarea 
          class="textarea" 
          placeholder="介绍一下自己（50字以内）" 
          value="{{bio}}" 
          bindinput="onBioInput" 
          maxlength="50"
          show-confirm-bar="{{false}}"
        />
        <text class="word-count">{{bio.length}}/50</text>
      </view>

      <!-- 提交按钮 -->
      <view class="submit-btn-box">
        <button 
          class="submit-btn" 
          bindtap="submit" 
          disabled="{{submitting}}"
          hover-class="none"
        >
          {{submitting ? '保存中...' : '保存'}}
        </button>
      </view>
    </view>
  </scroll-view>
</view>