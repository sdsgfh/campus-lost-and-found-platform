/* pages/message/message.wxss */
page {
  background: #e6f2e6;
  height: 100%;
  padding: 0;
  margin: 0;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
}

.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

.message-container {
  width: 100%;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 导航栏（修复高度+标题居中） */
.nav-box {
  width: 100%;
  background: #A5CFA9;
  height: 138rpx; /* 修复异常高度 */
  box-sizing: border-box;
  position: sticky;
  top: 0;
  z-index: 100;
  padding-top: var(--status-bar-height, 20px);
}

.nav-bar {
  height: 88rpx; /* 匹配导航栏高度 */
  display: flex;
  align-items: center;
  padding: 90rpx 24rpx; /* 优化内边距 */
  box-sizing: border-box;
}

.nav-title {
  flex: 1;
  text-align: center; /* 修复标题偏移，居中显示 */
  font-size: 34rpx;
  font-weight: 600;
  color: #207F4C;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  padding-left: 55rpx; /* 移除多余偏移 */
}

.nav-right {
  width: 60rpx;
  text-align: right;
  color: #207F4C;
  font-size: 28rpx;
  flex-shrink: 0;
}

/* Tab切换栏（优化选中样式） */
.tab-bar {
  display: flex;
  height: 88rpx; /* 统一高度 */
  background: #A5CFA9;
  border-bottom: 2rpx solid rgba(240, 240, 240, 0.2);
}
.tab-item {
  flex: 1;
  text-align: center;
  line-height: 88rpx;
  font-size: 30rpx;
  color: #666;
  position: relative;
}
.tab-item.active {
  color: #2E7D32;
  font-weight: 600;
}
/* 选中下划线优化 */
.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #2E7D32;
  border-radius: 2rpx;
}

/* 滚动列表（修复高度计算） */
.list-scroll {
  height: calc(100vh - 88rpx - var(--status-bar-height, 20px) - 88rpx);
  box-sizing: border-box;
  padding-bottom: 20rpx; /* 底部留白 */
}
.list {
  padding: 24rpx;
}

/* 通知项样式（移除编辑态相关） */
.notification-item {
  background: white;
  margin-bottom: 16rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  transition: transform 0.2s ease;
}
/* 点击反馈 */
.notification-item:active {
  transform: scale(0.98);
}
.notification-content {
  width: 100%;
}
.item-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.notification-item .title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  max-width: 70%;
}
.time {
  font-size: 24rpx;
  color: #999;
}
.content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: block;
}
.footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.read-status {
  font-size: 24rpx;
  color: #ff9800;
}
.read-status.read {
  color: #999;
}

/* 会话项样式（保留私信编辑态） */
.session-item {
  background: white;
  margin-bottom: 16rpx;
  padding: 16rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  position: relative; /* 作为未读标记的定位父容器 */
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  transition: transform 0.2s ease;
}
.session-item:active {
  transform: scale(0.98);
}
.session-item.editing .session-content {
  margin-left: 40rpx;
}
.session-item.editing .unread {
  right: 16rpx;
}
.session-checkbox {
  position: absolute;
  left: 12rpx;
  top: 30%;
  transform: translateY(-50%);
  z-index: 10;
  width: 20rpx;
  height: 20rpx;
  transform: scale(0.9);
}
.session-content {
  width: 100%;
  display: flex;
  align-items: center;
}
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  position: relative;
}
.avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}
.status-dot {
  position: absolute;
  top: 0;
  right: 0;
  width: 16rpx;
  height: 16rpx;
  background: #f56c6c;
  border-radius: 50%;
}
.info {
  flex: 1;
  min-width: 0;
}
.top-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}
.nickname {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  max-width: 60%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.bottom-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.last-msg {
  font-size: 26rpx;
  color: #666;
  max-width: 100%; /* 取消宽度限制，因为未读标记移走了 */
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.unread {
  position: absolute; /* 绝对定位 */
  top: 16rpx;         /* 顶部距离 */
  right: 16rpx;       /* 右侧距离 */
  background: #f56c6c;
  color: white;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 30rpx;
  min-width: 32rpx;
  text-align: center;
  z-index: 1; /* 确保在最上层 */
}
.post-tag {
  position: absolute;
  bottom: 8rpx;
  right: 16rpx;
  font-size: 22rpx;
  color: #518b54;
  background: #e8f5e8;
  padding: 4rpx 12rpx;
  border-radius: 30rpx;
  z-index: 0; /* 低于未读标记 */
}

/* 状态提示 */
.loading-more, .no-more, .empty {
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #999;
}
.empty {
  padding: 80rpx 0;
}
.batch-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: white;
  border-top: 2rpx solid #f0f0f0;
}
.select-all {
  display: flex;
  align-items: center;
  flex: 1;                /* 占据剩余空间，让按钮自动靠右 */
  white-space: nowrap;    /* 禁止文字换行 */
  font-size: 28rpx;
  color: #333;
}
.cancel-btn,
.delete-btn {
  flex-shrink: 0;         /* 防止按钮被压缩 */
  width: 100rpx;          /* 可调小一点，例如120rpx */
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 36rpx;
  font-size: 28rpx;
  border: none;
}
.delete-btn {
  background: #f56c6c;
  color: white;
}
.cancel-btn {
  background: #f5f5f5;
  color: #333;
}
.delete-btn[disabled] {
  background: #ccc;
}
/* 批量操作栏（仅私信） */
.batch-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  border-top: 2rpx solid #f0f0f0;
  padding: 20rpx 24rpx;
  display: flex;           /* 关键：使子元素水平排列 */
  align-items: center;
  justify-content: space-between;
  z-index: 100;
}
.cancel-btn,
.delete-btn {
  width: 150rpx;
  height: 72rpx;
  line-height: 72rpx;      /* 与高度一致实现垂直居中 */
  text-align: center;
  border-radius: 36rpx;
  font-size: 28rpx;
  border: none;
}
.cancel-btn {
  background: #f5f5f5;
  color: #333;
}
.delete-btn {
  background: #f56c6c;
  color: white;
}
.delete-btn[disabled] {
  background: #ccc;
}

/* 通知详情弹窗样式（优化交互+样式） */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.5);
  z-index: 999;
}
.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 85%;
  background: white;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
  z-index: 1000;
  max-height: 80vh;
  overflow-y: auto;
}
.modal-header {
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #518b54;
}
.close-icon {
  width: 32rpx;
  height: 32rpx;
  font-size: 32rpx;
  color: #999;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  cursor: pointer;
}
.close-icon:active {
  color: #333;
}
.modal-body {
  padding: 24rpx;
}
.detail-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
  text-align: center;
}
.detail-time {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 24rpx;
  text-align: center;
}
.detail-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  display: block;
  margin-bottom: 32rpx;
  white-space: pre-wrap; /* 支持换行 */
}
/* 统一按钮样式 */
.detail-btn, .appeal-btn {
  width: 100%;
  height: 88rpx;
  line-height: 68rpx;
  background: #69a06b;
  color: white;
  border-radius: 44rpx;
  font-size: 30rpx;
  border: none;
  margin-bottom: 16rpx;
  transition: background 0.2s ease;
}
/* 按钮点击反馈 */
.detail-btn:active, .appeal-btn:active {
  background: #2E7D32;
}
/* 最后一个按钮取消底部间距 */
.modal-body button:last-child {
  margin-bottom: 0;
}