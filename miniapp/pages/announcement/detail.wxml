<view class="page-wrapper">
  <image class="page-bg" src="/images/波浪.png" mode="aspectFill"></image>
  
  <!-- 导航栏 -->
  <view class="nav-box" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-bar">
      <view class="nav-back" bindtap="goBack">
        <image class="back-img" src="/images/返回.png" mode="widthFix"></image>
      </view>
      <view class="nav-title">公告详情</view>
      <view class="nav-right"></view>
    </view>
  </view>

  <!-- 内容滚动区（绑定动态高度） -->
  <scroll-view 
    class="content-scroll" 
    scroll-y 
    style="height: {{scrollHeight}};"
  >
    <view class="list">
      <!-- 公告详情 -->
      <view class="card" wx:if="{{announcement}}">
        <view class="card-header">
          <text class="title">{{announcement.title}}</text>
          <text class="time">{{announcement.create_time}}</text>
        </view>
        <view class="card-content">{{announcement.content}}</view>
      </view>

      <!-- 空状态 -->
      <view class="empty" wx:elif="!announcement">暂无公告详情</view>
    </view>
  </scroll-view>
</view>