/* 全局样式重置 */
page {
  background-color: #e6f2e6dd;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  height: 100vh;
  overflow: hidden;
  padding: 0;
  margin: 0;
}

/* 背景图 */
.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

/* 主容器 */
.history-container {
  width: 100%;
  height: 100vh;
  position: relative;
  box-sizing: border-box;
}

/* 自定义导航栏（统一样式） */
.nav-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 105rpx 24rpx 10rpx;
  background: #A5CFA9;
}
.back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.back-icon {
  width: 20rpx;
  height: 30rpx;
}

/* 导航栏标题 */
.title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #207F4C;
}

.right {
  width: 80rpx;
}

/* 列表滚动区域 */
.list-scroll {
  position: absolute;
  top: 180rpx;  
  left: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  box-sizing: border-box;
  overflow-y: auto;
}

/* 列表容器 */
.list {
  padding: 30rpx 24rpx;
}

/* 反馈列表项 */
.feedback-item {
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.05);
  transition: all 0.2s ease;
}

.feedback-item:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}

/* 列表项头部 */
.item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

/* 反馈内容 */
.content {
  font-size: 30rpx;
  color: #333;
  flex: 1;
  margin-right: 20rpx;
  word-break: break-word;
  line-height: 1.5;
}

.line-clamp-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 状态标签 */
.status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}

.status.pending {
  background: #fff3e0;
  color: #ff9800;
}

.status.replied {
  background: #e8f5e8;
  color: #2E7D32;
}

/* 列表项底部 */
.item-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 时间 */
.time {
  font-size: 26rpx;
  color: #999;
}

/* 有回复标签 */
.replied {
  font-size: 24rpx;
  color: #2E7D32;
  background: #e8f5e8;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 加载/空状态提示 */
.loading-more, .no-more, .empty {
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #999;
}

.empty {
  padding: 80rpx 0;
  font-size: 28rpx;
}

/* 弹窗遮罩 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 999;
}

/* 弹窗容器 */
.modal-container {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 90%;
  max-width: 600rpx;
  background-color: #fff;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.15);
  z-index: 1000;
  max-height: 80vh;
}

/* 弹窗头部 */
.modal-header {
  padding: 24rpx 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
}

.close-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #999;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.close-btn:active {
  background-color: #f0f0f0;
  color: #666;
}

/* 弹窗内容区 */
.modal-content {
  padding: 13rpx;
  max-height: 60vh;
}

/* 详情项 */
.detail-item {
  margin-bottom: 30rpx;
}

/* 详情标签 */
.detail-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
  font-weight: 500;
}

/* 详情值 */
.detail-value {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  word-break: break-word;
}

/* 图片容器 */
.images-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 10rpx;
}

/* 详情图片 */
.detail-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
}

/* 回复内容 */
.reply-content {
  border-radius: 12rpx;
}
.reply-content text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
}
.reply-time {
  font-size: 26rpx;
  color: #999;
  display: block;
  text-align: right;
}