/* 页面基础样式 */
.page {
  width: 100%;
  min-height: 100vh;
  background-color: #e6f2e655;
}

.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

/* 自定义导航栏 */
.custom-nav {
  width: 100%;
  background: #A5CFA9;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  padding: 0 20rpx;
}

.nav-back {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 20rpx;
  height: 30rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #207F4C;
}

.nav-right {
  width: 44rpx;
}

/* 表单滚动区域 */
.form-scroll {
  width: 100%;
  box-sizing: border-box;
}

.form-container {
  padding: 30rpx 20rpx;
  box-sizing: border-box;
}

/* 表单项 */
.form-item {
  margin-bottom: 40rpx;
}

.label {
  font-size: 32rpx;
  color: #538d56;
  font-weight: 600;
  margin-bottom: 15rpx;
  display: block;
}

.required {
  color: #f44336;
  font-size: 28rpx;
}

.optional {
  color: #999;
  font-size: 28rpx;
  font-weight: normal;
}

/* 申诉类型行 */
.type-item {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
}

.type-item .label {
  margin-bottom: 0;
  margin-right: 10rpx;
}

.type-value {
  font-size: 32rpx;
  color: #2e7d32;
  font-weight: 550;
}
/* 文本域 */
.textarea-wrap {
  position: relative;
  width: 100%;
}

.textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  box-sizing: border-box;
  border: 1px solid #eee;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #fff;
}

.word-count {
  position: absolute;
  right: 20rpx;
  bottom: 10rpx;
  font-size: 24rpx;
  color: #999;
}

/* 图片上传 */
.upload-area {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 15rpx;
}

.upload-preview {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 10rpx;
  overflow: hidden;
}

.preview-img {
  width: 100%;
  height: 100%;
}

.uploading-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.uploading-text {
  color: #fff;
  font-size: 24rpx;
}

.remove-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: #f44336;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
}

.upload-btn {
  width: 160rpx;
  height: 160rpx;
  border: 1px dashed #ddd;
  border-radius: 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #fff;
}

.plus {
  font-size: 48rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.tip {
  font-size: 24rpx;
  color: #999;
}

.upload-tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 15rpx;
  display: block;
}

/* 提交按钮 */
.submit-btn-box {
  margin-top: 60rpx;
  padding: 0 20rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 68rpx;
  background-color: #2e7d32;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
}

.submit-btn[disabled] {
  background-color: #ccc !important;
  color: #fff !important;
}