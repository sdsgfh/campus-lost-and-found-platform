<!-- 背景图 -->
<image class="page-bg" src="/images/波浪.png"></image>

<view class="setting-container">
  <!-- 自定义导航栏（优化样式） -->
  <view class="nav-bar">
    <view class="back-btn" bindtap="goBack">
      <image src="/images/返回.png" class="back-icon" mode="widthFix"></image>
    </view>
    <text class="nav-title">系统设置</text>
    <view class="nav-right"></view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="goToPage" data-url="/pages/setting/cancel-account">
      <text class="item-text">账号注销</text>
      <view class="item-arrow"></view>
    </view>
    <!-- 保留清理缓存（实用功能） -->
    <view class="menu-item" bindtap="clearCache">
      <text class="item-text">清理缓存</text>
      <text class="cache-size">{{cacheSize}}</text>
    </view>
    <view class="menu-item" bindtap="goToPage" data-url="/pages/about/about">
      <text class="item-text">关于我们</text>
      <view class="item-arrow"></view>
    </view>
    <view class="menu-item" bindtap="goToPage" data-url="/pages/feedback/feedback">
      <text class="item-text">意见反馈</text>
      <view class="item-arrow"></view>
    </view>
    <view class="menu-item" bindtap="goToPage" data-url="/pages/feedback/history">
      <text class="item-text">反馈历史</text>
      <view class="item-arrow"></view>
    </view>
  </view>

  <view class="logout-btn" bindtap="logout">
    <text class="logout-text">退出登录</text>
  </view>
</view>