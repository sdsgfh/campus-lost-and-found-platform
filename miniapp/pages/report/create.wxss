/* pages/report/create.wxss */
.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

page {
  background-color: #e6f2e6d3;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 90rpx;
  padding: 85rpx 24rpx 0;
  background: #A5CFA9;
  backdrop-filter: blur(10rpx);
  position: sticky;
  top: 0;
  z-index: 90;
}
.back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.back-icon {
  width: 20rpx;
  height: 30rpx;
  object-fit: contain;
}
.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #207F4C;
}
.right {
  width: 60rpx;
}

.form-scroll {
  height: calc(100vh - 96rpx);
}
.form-container {
  padding: 32rpx 24rpx;
}

.form-item {
  margin-bottom: 40rpx;
}
.label {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 20rpx;
  display: block;
}
.required {
  color: #f56c6c;
  margin-left: 6rpx;
}
.optional {
  color: #999;
  font-size: 26rpx;
  margin-left: 10rpx;
}

/* 选项组 */
.option-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.option-tag {
  padding: 16rpx 32rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}
.option-tag.selected {
  background: #69a06b;
  color: white;
}

/* 目标信息 */
.target-info {
  background: #f5f8f5;
  padding: 24rpx;
  border-radius: 16rpx;
}
.target-type {
  font-size: 26rpx;
  color: #999;
  margin-right: 16rpx;
}
.target-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

/* 文本域 */
.textarea {
  width: 100%;
  height: 200rpx;
  background: #f7f8f7;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  border: 2rpx solid #e0e8e0;
  box-sizing: border-box;
}
.word-count {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  font-size: 22rpx;
  color: #999;
}

/* 图片上传 */
.upload-area {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.upload-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  position: relative;
  overflow: hidden;
}
.preview-img {
  width: 100%;
  height: 100%;
}
.remove-btn {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 32rpx;
  height: 32rpx;
  background-color: rgba(0,0,0,0.5);
  color: white;
  border-radius: 50%;
  text-align: center;
  line-height: 32rpx;
  font-size: 24rpx;
}
.upload-btn {
  width: 160rpx;
  height: 160rpx;
  background: #f7f8f7;
  border: 2rpx dashed #b8c9b8;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.plus {
  font-size: 48rpx;
  color: #2E7D32;
  line-height: 1;
  margin-bottom: 8rpx;
}
.tip {
  font-size: 22rpx;
  color: #2E7D32;
}
.upload-tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
  display: block;
}

/* 提交按钮 */
.submit-btn-box {
  margin-top: 60rpx;
}
.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 76rpx;
  background: #69a06b;
  color: #fff;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 600;
  border: none;
}
.submit-btn[disabled] {
  opacity: 0.6;
  background: #ccc;
}