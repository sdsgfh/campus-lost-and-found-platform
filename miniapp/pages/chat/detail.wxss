/* pages/chat/detail.wxss */
page {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  height: 100%;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
}

/* 背景图 */
.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
  opacity: 0.8;
}

.chat-container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  /* 修复：防止容器溢出导致图片被裁切 */
  overflow: hidden;
}

/* 自定义导航栏 */
.custom-nav {
  width: 100%;
  background: #A5CFA9;
  box-sizing: border-box;
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 2rpx solid #E5E5E5;
}
.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
}
.nav-back {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.back-icon {
  width: 20rpx;
  height: 30rpx;
  object-fit: contain;
}
.user-info {
  display: flex;
  align-items: center;
  flex: 1;
  margin-left: 16rpx;
}
.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.nickname {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.nav-right {
  width: 80rpx;
  text-align: right;
  font-size: 32rpx;
  color: #666;
  flex-shrink: 0;
}

/* 关联帖子信息 */
.post-info {
  background: #F8F8F8;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  color: #666;
  border-bottom: 2rpx solid #E5E5E5;
  flex-shrink: 0;
}
.post-label {
  color: #999;
}
.post-title {
  color: #07C160;
}

/* 聊天区域 - 核心修复：增加min-height，确保滚动容器高度正常 */
.chat-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx;
  box-sizing: border-box;
  min-height: 0; /* 修复flex布局下的高度计算问题 */
}
.message-list {
  display: flex;
  flex-direction: column;
  width: 100%; /* 强制占满宽度 */
}
/* 核心修复：消息项的flex布局，确保图片容器有足够空间 */
.message-item {
  display: flex;
  margin-bottom: 24rpx;
  align-items: flex-end;
  width: 100%;
  box-sizing: border-box;
  /* 修复：防止子元素溢出 */
  overflow: visible;
}
.message-item.me {
  flex-direction: row-reverse;
}

/* 内容容器 - 核心修复：调整最大宽度和对齐方式 */
.content-wrapper {
  max-width: 70%;
  min-width: 60rpx;
  display: flex;
  flex-direction: column;
  /* 修复：移除width: auto，避免挤压图片 */
  word-break: break-all;
  overflow-wrap: break-word;
  box-sizing: border-box;
}
.message-item.me .content-wrapper {
  align-items: flex-end;
}

/* 消息气泡 */
.bubble {
  display: inline-block;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.5;
  white-space: pre-wrap;
  word-break: break-all;
  overflow-wrap: break-word;
  max-width: 100%;
  box-sizing: border-box;
}
.message-item.other .bubble {
  background-color: #FFFFFF;
  border: 2rpx solid #E5E5E5;
  color: #333;
  border-top-left-radius: 4rpx;
}
.message-item.me .bubble {
  background-color: #6baa89aa;
  color: #FFFFFF;
  border-top-right-radius: 4rpx;
}

/* 图片气泡 - 终极修复：解决所有显示问题 */
.image-bubble {
  padding: 0 !important; 
  /* 修复：固定宽高范围，同时允许自适应 */
  width: 200rpx !important;
  height: 200rpx !important;
  min-width: 100rpx !important;
  min-height: 100rpx !important;
  /* 修复：强制显示，优先级最高 */
  display: block !important;
  visibility: visible !important;
  opacity: 1 !important;
  /* 修复：层级高于背景，避免被遮挡 */
  z-index: 1 !important;
  /* 修复：边框和圆角适配 */
  border: none !important;
}
/* 聊天图片 - 终极修复 */
.chat-image {
  width: 100% !important;
  height: 100% !important;
  border-radius: 16rpx !important;
  object-fit: cover !important;
  /* 修复：强制显示，解决小程序image组件默认隐藏问题 */
  display: block !important;
  visibility: visible !important;
  opacity: 1 !important;
  /* 修复：避免图片加载前占位为0 */
  background-color: #f5f5f5;
}

/* 消息时间 */
.time {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  padding: 0 8rpx;
}
.message-item.me .time {
  text-align: right;
}

/* 底部输入区域 */
.input-area {
  display: flex;
  align-items: center;
  padding: 30rpx 60rpx;
  background: #A5CFA9;
  border-top: 2rpx solid #E5E5E5;
  flex-shrink: 0;
  gap: 16rpx;
  box-sizing: border-box;
}
.text-input {
  flex: 1;
  height: 72rpx;
  background: #F5F5F5;
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.upload-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.upload-icon {
  width: 40rpx;
  height: 40rpx;
  object-fit: contain;
}