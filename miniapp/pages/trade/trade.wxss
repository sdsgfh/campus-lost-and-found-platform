/* 全局重置 */
page {
  background: #e6f2e6;
  height: 100vh;
  overflow: hidden;
  padding: 0;
  margin: 0;
}
.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}
.page-wrapper {
  width: 100%;
  height: 100vh;
  position: relative; /* 父容器相对定位，子元素绝对定位 */
}

/* 1. 导航栏 - 固定顶部 */
.nav-box {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  background: #A5CFA9;
  height:65rpx;
  z-index: 100;
}
.nav-bar {
  height: 100%;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
}
.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #207F4C;
}
.nav-right {
  width: 60rpx;
}

/* 2. 搜索栏 - 导航栏下方 */
.search-bar-section {
  position: absolute;
  top: 160rpx;
  left: 0;
  right: 0;
  background: #A5CFA9; 
  padding: 20rpx 16rpx;
  z-index: 99;
  height: 100rpx;
  box-sizing: border-box;
}
.search-bar {
  display: flex;
  align-items: center;
  width: 100%;
  height: 100%;
}
.search-input-box {
  flex: 1;
  height: 80rpx;
  background: #fff;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  margin-right: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(46, 125, 50, 0.05);
}
.search-icon-img {
  width: 52rpx;
  height: 52rpx;
  margin-right: 16rpx;
}
.search-placeholder {
  font-size: 28rpx;
  color: #b0b7b3;
}
.filter-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 12rpx rgba(46, 125, 50, 0.05);
}
.filter-img {
  width: 40rpx;
  height: 40rpx;
}

/* 3. Tab栏 - 搜索栏下方 */
.tab-section {
  position: absolute;
  top: 255rpx;
  left: 0;
  right: 0;
  background: #A5CFA9;
  padding: 0 16rpx;
  z-index: 98;
  height: 55rpx;
}
.tab-container {
  height: 100%;
  display: flex;
  position: relative;
}
.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #666;
}
.tab-item.active {
  color: #2E7D32;
  font-weight: bold;
}
.tab-indicator {
  position: absolute;
  bottom: 0;
  width: 50%;
  height: 4rpx;
  background: #518b54;
  border-radius: 2rpx;
  transition: transform 0.3s;
}

/* 4. 排序栏 - Tab栏下方 */
.sort-section {
  position: absolute;
  top: 310rpx;
  left: 0;
  right: 0;
  background: #A5CFA9;
  padding: 16rpx;
  z-index: 97;
}
.sort-grid {
  display: grid;
  gap: 20rpx;
}
.grid-3 {
  grid-template-columns: repeat(3, 1fr);
}
.sort-tag {
  height: 50rpx;
  border: 2rpx solid #E0E0E0;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  color: #666;
  background: #fff;
}
.sort-tag.selected {
  background: #83b585;
  color: #fff;
  border-color: #7bab7d;
}

/* 5. 列表区域 - 排序栏下方 */
.list-section {
  position: absolute;
  top: 420rpx; /* 导航+搜索+Tab+排序 总高度 */
  left: 0;
  right: 0;
  bottom: 0;
  padding: 0 16rpx 0;
  box-sizing: border-box;
  overflow: hidden;
}
.content-scroll {
  height: 100%;
  width: 100%;
}
.content-scroll::-webkit-scrollbar {
  width: 0;
  display: none;
}
.content-list {
  padding-top: 8rpx;
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 24rpx;
  display: flex;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}
.card-img {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
  position: relative;
}
.real-img {
  width: 100%;
  height: 100%;
}
.card-info {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.card-title {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 12rpx;
}
.card-price {
  font-size: 36rpx;
  color: #eb6461;
  font-weight: bold;
  margin-bottom: 16rpx;
  display: block;
}
.card-time {
  font-size: 24rpx;
  color: #999;
}

/* 状态提示 */
.empty-tip, .error-tip, .no-more {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
}
.error-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}
.refresh-btn {
  background: #2E7D32;
  color: #fff;
  border-radius: 36rpx;
  padding: 0 30rpx;
  margin-top: 20rpx;
}
.loading-status {
  text-align: center;
  padding: 20rpx 0;
  color: #999;
}
.no-more {
  padding: 40rpx 0;
  font-size: 28rpx;
}

/* 发布按钮 */
.publish-btn {
  position: fixed;
  bottom: 8rpx;
  right: 34rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99;
}
.publish-img {
  width: 166rpx;
  height: 166rpx;
}

/* 筛选弹窗 */
.overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.2);
  z-index: 1000;
}
.filter-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 0.3s;
  max-height: 90vh;
  overflow-y: auto;
}
.filter-panel.active {
  transform: translateY(0);
}
.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}
.panel-title {
  font-size: 36rpx;
  color: #69956a;
  font-weight: bold;
  flex: 1;
  text-align: center;
}
.close-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.group-title-with-icon {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.group-icon {
  width: 38rpx;
  height: 38rpx;
  margin-right: 12rpx;
}
.group-title-with-icon text {
  font-size: 32rpx;
  color: #77a979;
  font-weight: bold;
}
.option-grid {
  display: grid;
  gap: 16rpx;
  margin-bottom: 30rpx;
}
.grid-2 {
  grid-template-columns: repeat(3, 1fr);
}
.option-tag {
  height: 72rpx;
  border: 2rpx solid #E0E0E0;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
}
.option-tag.selected {
  background: #88c18b;
  color: #fff;
  border-color: #7cbd7f;
}
.panel-footer {
  display: flex;
  gap: 30rpx;
}
.btn-reset {
  flex: 1;
  height: 88rpx;
  border: 2rpx solid #77a979;
  border-radius: 16rpx;
  color: #77a979;
  background: #fff;
  font-size: 32rpx;
}
.btn-confirm {
  flex: 1;
  height: 88rpx;
  background: #88c18b;
  color: #fff;
  border-radius: 16rpx;
  font-size: 32rpx;
}